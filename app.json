{
  "expo": {
    "name": "Drive",
    "slug": "drive",
    "description": "App para control/manejo de señales y pulsos mediante conexión App-Bluetooth.",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/App_logo.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.carrocatolica.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/App_logo.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "BLUETOOTH_CONNECT",
        "BLUETOOTH_SCAN",
        "BLUETOOTH_ADVERTISE",
        "ACCESS_FINE_LOCATION"
      ],
      "package": "com.carrocatolica.app"
    },
    "plugins": [
      "with-rn-bluetooth-classic",
      "expo-asset",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "174d733d-6031-4966-ab0c-4218e786b6d0"
      }
    }
  }
}
